# Copy to .env for local development. NEVER commit a real .env (see .gitignore).
# Production values are set in the Railway dashboard, not in any committed file.

# Prisma connection string (Railway injects this automatically in prod)
DATABASE_URL="postgresql://impact:impact@localhost:5432/impact_dashboard?schema=public"

# Session cookie encryption key — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# App public URL (http://localhost:3000 in dev; Railway domain in prod)
NEXTAUTH_URL="http://localhost:3000"
